import json
import random
import urllib.error
import urllib.request
from pathlib import Path


CONFIG_PATH = Path(__file__).with_name("jarvis_config.json")


def load_config():
    defaults = {
        "groq_api_key": "",
        "groq_model": "llama-3.1-8b-instant",
        "edge_tts_voice": "ru-RU-DmitryNeural",
        "tts_cache_dir": str(Path(__file__).with_name("tts_cache")),
        "ai_enabled": True,
        "tts_enabled": True,
    }
    try:
        data = json.loads(CONFIG_PATH.read_text(encoding="utf-8"))
        if isinstance(data, dict):
            defaults.update(data)
    except (OSError, json.JSONDecodeError):
        pass
    return defaults


class GroqJarvisAI:
    def __init__(self):
        self.config = load_config()
        self.api_key = self.config.get("groq_api_key", "").strip()
        self.model = self.config.get("groq_model", "llama-3.1-8b-instant")
        self.enabled = bool(self.config.get("ai_enabled", True) and self.api_key)
        self.client = None
        if self.enabled:
            try:
                from groq import Groq
                self.client = Groq(api_key=self.api_key)
            except Exception:
                self.client = None

    def available(self):
        return self.enabled

    def command_ack(self, sound_key, fallback, command_text=""):
        if not self.available():
            return fallback
        intent = {
            "welcome": "поприветствуй пользователя как Джарвис",
            "status_ok": "ответь, что система работает нормально",
            "yes": "коротко подтверди, что готов записать текст",
            "doing": "коротко скажи, что выполняешь команду",
            "thanks": "ответь на благодарность",
            "site": "скажи, что открываешь сайт",
            "plan": "одобри план пользователя",
            "ask_plan": "спроси, что пользователь планирует сегодня",
            "ask_timer": "спроси, на сколько времени поставить таймер",
            "timer_set": "скажи, что таймер поставлен",
            "timer_done": "напомни, что время таймера истекло",
            "confused": "с юмором отреагируй на фразу пользователя",
            "start": "скажи, что включаешь воспроизведение",
            "ok": "подтверди выполнение команды",
            "good": "подтверди успешное действие",
            "unknown": "скажи, что запрос непонятен",
            "help": "спроси, чем можешь помочь",
            "remembered": "скажи, что запомнил",
            "remember_show": "скажи, что показываешь сохраненную заметку",
            "reminder_set": "скажи, что напоминание поставлено",
            "reminder_due": "скажи, что пользователь просил напомнить",
            "rest_choice": "спроси, как пользователь хочет отдохнуть",
            "work_choice": "спроси, какой рабочий вариант выбрать",
            "rest_done": "пожелай приятного отдыха",
            "work_done": "пожелай хорошо поработать",
            "will_do": "скажи, что будет сделано",
        }.get(sound_key, "коротко подтверди действие")
        prompt = (
            f"Ситуация: {intent}. "
            f"Команда пользователя: {command_text or 'не указана'}. "
            "Ответь одной короткой фразой на русском, 2-8 слов. "
            "Стиль: спокойный Джарвис, обращайся 'сэр' не всегда, но часто. "
            "Не используй английские слова, включая sir. Пиши только 'сэр'. "
            "Не объясняй, не ставь кавычки."
        )
        return self._request(prompt, max_tokens=45, temperature=0.95) or fallback

    def chat(self, text, history=None):
        if not self.available():
            return "Сэр, ИИ сейчас недоступен, но локальные команды работают."
        messages = [
            {
                "role": "system",
                "content": (
                    "Ты Джарвис: умный, спокойный, слегка ироничный голосовой ассистент. "
                    "Отвечай по-русски, кратко и естественно. "
                    "Не используй английское sir, только русское 'сэр'. "
                    "Не притворяйся человеком. Не управляй компьютером текстом, если команда уже не была выполнена локально. "
                    "Если пользователь просто болтает, поддержи разговор. "
                    "Обычно 1-3 предложения."
                ),
            }
        ]
        for item in (history or [])[-8:]:
            role = item.get("role")
            content = item.get("content")
            if role in ("user", "assistant") and content:
                messages.append({"role": role, "content": content})
        messages.append({"role": "user", "content": text})
        return self._chat_request(messages, max_tokens=220, temperature=0.75) or random.choice([
            "Сэр, связь с ИИ не отвечает, но я всё ещё на месте.",
            "Не смог достучаться до Groq, сэр. Попробуем ещё раз позже.",
        ])

    def _request(self, prompt, max_tokens=80, temperature=0.8):
        messages = [
            {"role": "system", "content": "Ты голос Джарвиса. Пиши только готовую фразу для озвучки."},
            {"role": "user", "content": prompt},
        ]
        return self._chat_request(messages, max_tokens=max_tokens, temperature=temperature)

    def _chat_request(self, messages, max_tokens=160, temperature=0.7):
        if not self.api_key:
            return ""
        if self.client:
            try:
                completion = self.client.chat.completions.create(
                    model=self.model,
                    messages=messages,
                    temperature=temperature,
                    max_tokens=max_tokens,
                )
                text = completion.choices[0].message.content.strip()
                return " ".join(text.replace("\n", " ").split())
            except Exception:
                pass
        body = {
            "model": self.model,
            "messages": messages,
            "temperature": temperature,
            "max_tokens": max_tokens,
        }
        request = urllib.request.Request(
            "https://api.groq.com/openai/v1/chat/completions",
            data=json.dumps(body).encode("utf-8"),
            headers={
                "Authorization": f"Bearer {self.api_key}",
                "Content-Type": "application/json",
            },
            method="POST",
        )
        try:
            with urllib.request.urlopen(request, timeout=12) as response:
                payload = json.loads(response.read().decode("utf-8"))
            text = payload["choices"][0]["message"]["content"].strip()
            return " ".join(text.replace("\n", " ").split())
        except (OSError, urllib.error.URLError, KeyError, IndexError, json.JSONDecodeError):
            return ""
